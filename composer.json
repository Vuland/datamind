{
    "name": "datamind/datamind",
    "description": "Datamind",
    "keywords": ["yii2", "mongodb", "elasticsearch", "import", "xlsx"],
    "homepage": "https://github.com/datamind/",
    "type": "project",
    "license": "BSD-3-Clause",
    "support": {},
    "minimum-stability": "stable",
    "require": {
        "php": "^8.1",
        "ext-iconv": "*",
        "ext-mongodb": "*",
        "maennchen/zipstream-php": "^2.1",
        "ramsey/uuid": "^4.7",
        "elasticsearch/elasticsearch": "^7.17",
        "monolog/monolog": "^3.0",
        "phpoffice/phpspreadsheet": "^2.4",
        "yiisoft/yii2": "~2.0.45",
        "yiisoft/yii2-bootstrap5": "~2.0.2",
        "yiisoft/yii2-mongodb": "^2.1",
        "yiisoft/yii2-symfonymailer": "~2.0.3",
        "webmozart/assert": "^1.12"
    },
    "require-dev": {
        "yiisoft/yii2-debug": "~2.1.0",
        "yiisoft/yii2-gii": "~2.2.0",
        "yiisoft/yii2-faker": "~2.0.0",
        "codeception/codeception": "^5.0, <5.3 || ^4.0",
        "codeception/lib-innerbrowser": "^4.0 || ^3.0 || ^1.1",
        "codeception/module-asserts": "^3.0, <3.3 || ^1.1",
        "codeception/module-yii2": "^1.1",
        "codeception/module-filesystem": "^3.0 || ^2.0 || ^1.1",
        "codeception/verify": "^3.0 || ^2.2"
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer" : true
        },
        "process-timeout": 1800,
        "fxp-asset": {
            "enabled": false
        }
    },
    "scripts": {
        "post-install-cmd": [
            "yii\\composer\\Installer::postInstall"
        ],
        "post-create-project-cmd": [
            "yii\\composer\\Installer::postCreateProject",
            "yii\\composer\\Installer::postInstall"
        ]
    },
    "autoload": {
        "psr-4": {
            "app\\": "",
            "Modules\\Aggregation\\": "modules/aggregation/src/",
            "Modules\\Config\\": "modules/config/src/",
            "Modules\\Import\\": "modules/import/src/",
            "Modules\\Index\\": "modules/index/src/"
        }
    },
    "extra": {},
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ]
}
